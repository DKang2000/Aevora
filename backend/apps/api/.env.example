# Aevora API local environment template
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://aevora:aevora@localhost:5432/aevora_dev?schema=public
API_BASE_URL=http://localhost:3000
AUTH_ISSUER=aevora-local
AUTH_AUDIENCE=aevora-ios
ANALYTICS_PROVIDER=console
OBSERVABILITY_PROVIDER=console
REMOTE_CONFIG_SOURCE=file
CONTENT_SOURCE=file
