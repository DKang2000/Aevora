{
  "name": "@aevora/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:postgres": "AEVORA_ENABLE_POSTGRES_E2E=true CORE_LOOP_PERSISTENCE=prisma jest --config ./test/jest-e2e.json --runInBand ./test/core-loop.postgres.e2e-spec.ts",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "migrate:status": "prisma migrate status",
    "migrate:deploy": "prisma migrate deploy",
    "validate:analytics": "ts-node scripts/validate-analytics.ts",
    "validate:datasets": "ts-node scripts/validate-datasets.ts"
  },
  "dependencies": {
    "@aevora/analytics-schema": "workspace:*",
    "@nestjs/common": "^11.0.7",
    "@nestjs/core": "^11.0.7",
    "@nestjs/platform-express": "^11.0.7",
    "@prisma/client": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.19.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
